# Copia este archivo a .env.local y rellena los valores.
# Guía completa: docs/DEPLOY-VERCEL.md

# ── Supabase (obligatorio) ─────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave pública (anon). También vale NEXT_PUBLIC_SUPABASE_ANON_KEY (alias).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Secreto servidor. NUNCA en el cliente. Obligatorio en producción.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Cron Vercel (obligatorio en producción) ────────────────────────────────
# Cadena larga inventada por ti; la misma en Vercel y aquí en local si pruebas cron.
CRON_SECRET=

# ── Stripe (obligatorio para cobros) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend — correos de bienvenida y avisos) ───────────────────────
# Guía: docs/RESEND-SETUP.md
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Transporte Social <onboarding@resend.dev>

# ── Admin (opcional — panel /admin/disputas) ───────────────────────────────
# UUIDs separados por coma. Si vacío, usa el email del titular en legal-info.ts
ADMIN_USER_IDS=
