# Copia este archivo a .env.local y rellena los valores desde Supabase
# Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Correo de bienvenida tras registro (opcional; sin clave el registro funciona igual)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Transporte Social <onboarding@resend.dev>

# Webhook Stripe (suscripción) y actualización de perfiles
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — suscripción 0,95 €/mes y aportación por publicación
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
